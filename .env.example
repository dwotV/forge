# ─────────────────────────────────────────────────────────────
#  Forge — Configuración de credenciales
#
#  Copia este archivo a ".env" y rellena los valores:
#    cp .env.example .env
#
#  El archivo .env NUNCA debe subirse al repositorio.
#  Ya está en .gitignore — no lo quites de ahí.
# ─────────────────────────────────────────────────────────────

# ── Linux User of forge enviroment ───────────────────────────
# Username (only letters, numbers and underscores)
KALI_USER=hacker

# Password
KALI_PASSWORD=hacker

# ── Resolution of VNC desktop (optional) ─────────────────────
VNC_RESOLUTION=1280x800
